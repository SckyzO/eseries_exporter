func TestInterfaceStatisticsCollector(t *testing.T) {
	// Load test data
	data, err := os.ReadFile("testdata/interface-statistics.json")
	require.NoError(t, err)

	// Create test server
	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		w.WriteHeader(http.StatusOK)
		w.Write(data)
	}))
	defer server.Close()

	// Create target
	target := config.Target{
		Name:     "test-array",
		Endpoint: server.URL,
	}

	// Create collector
	collector := NewInterfaceStatisticsExporter(target, log.NewNopLogger())

	// Create metrics channel
	ch := make(chan prometheus.Metric, 100)
	defer close(ch)

	// Collect metrics
	go func() {
		collector.Collect(ch)
	}()

	// Wait for collection to complete
	// We expect specific metrics based on our test data
	metrics := []string{
		"eseries_interface_iops_total",
		"eseries_interface_read_iops_total",
		"eseries_interface_write_iops_total",
		"eseries_interface_bytes_total",
		"eseries_interface_read_bytes_total",
		"eseries_interface_write_bytes_total",
		"eseries_interface_response_time_seconds",
		"eseries_interface_errors_total",
		"eseries_interface_link_utilization_ratio",
	}

	collectedMetrics := []string{}
	for metric := range ch {
		metricName := ""
		metric.Desc().String(&metricName)
		collectedMetrics = append(collectedMetrics, metricName)
	}

	// Verify that all expected metrics are present
	for _, expectedMetric := range metrics {
		found := false
		for _, collectedMetric := range collectedMetrics {
			if collectedMetric == expectedMetric {
				found = true
				break
			}
		}
		assert.True(t, found, "Expected metric %s not found in collected metrics", expectedMetric)
	}

	// Verify we collected metrics for both interfaces in test data
	interfaceMetrics := 0
	for metric := range ch {
		metricName := ""
		metric.Desc().String(&metricName)
		if len(metricName) > 0 && contains(metricName, "interface") {
			interfaceMetrics++
		}
	}
	// We expect 9 metrics per interface (9 metric types), and 2 interfaces = 18 total
	assert.True(t, interfaceMetrics >= 9, "Expected at least 9 metrics per interface")
}

func TestInterfaceStatisticsCollectorWithError(t *testing.T) {
	// Create server that returns error
	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		w.WriteHeader(http.StatusInternalServerError)
		io.Copy(w, &emptyReader{})
	}))
	defer server.Close()

	// Create target
	target := config.Target{
		Name:     "test-array",
		Endpoint: server.URL,
	}

	// Create collector
	collector := NewInterfaceStatisticsExporter(target, log.NewNopLogger())

	// Create metrics channel
	ch := make(chan prometheus.Metric, 100)
	defer close(ch)

	// Collect metrics - should not panic
	collector.Collect(ch)

	// Check that error metric is present
	errorMetricFound := false
	for metric := range ch {
		metricName := ""
		metric.Desc().String(&metricName)
		if contains(metricName, "collect_error") && contains(metricName, "interface-statistics") {
			errorMetricFound = true
			break
		}
	}
	assert.True(t, errorMetricFound, "Expected error metric for interface-statistics collector")
}

func TestInterfaceStatisticsCollectorEmptyResponse(t *testing.T) {
	// Create server that returns empty statistics
	server := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		w.WriteHeader(http.StatusOK)
		w.Write([]byte(`{"statistics": []}`))
	}))
	defer server.Close()

	// Create target
	target := config.Target{
		Name:     "test-array",
		Endpoint: server.URL,
	}

	// Create collector
	collector := NewInterfaceStatisticsExporter(target, log.NewNopLogger())

	// Create metrics channel
	ch := make(chan prometheus.Metric, 100)
	defer close(ch)

	// Collect metrics - should not panic with empty response
	collector.Collect(ch)

	// Should still have collect_duration and collect_error metrics
	durationMetricFound := false
	errorMetricFound := false

	for metric := range ch {
		metricName := ""
		metric.Desc().String(&metricName)
		if contains(metricName, "collect_duration") && contains(metricName, "interface-statistics") {
			durationMetricFound = true
		}
		if contains(metricName, "collect_error") && contains(metricName, "interface-statistics") {
			errorMetricFound = true
		}
	}

	assert.True(t, durationMetricFound, "Expected duration metric")
	assert.True(t, errorMetricFound, "Expected error metric with empty stats")
}

// emptyReader implements io.Reader for testing error cases
type emptyReader struct{}

func (r *emptyReader) Read(p []byte) (n int, err error) {
	return 0, io.EOF
}
